<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>scLens Data Profile — {{ summary.taskId }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; padding: 24px; background: #f5f5f5; color: #222; }
  h1 { font-size: 1.4rem; color: #1a1a2e; border-bottom: 2px solid #4C72B0; padding-bottom: 8px; }
  h2 { font-size: 1.1rem; color: #333; margin-top: 28px; }
  .card { background: #fff; border-radius: 8px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
  table { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
  th { background: #f0f4ff; text-align: left; padding: 8px 12px; }
  td { padding: 7px 12px; border-bottom: 1px solid #eee; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; }
  .badge-green { background: #d4edda; color: #155724; }
  .badge-gray  { background: #e2e3e5; color: #383d41; }
  .badge-orange { background: #fff3cd; color: #856404; }
  .figure { max-width: 100%; border-radius: 4px; margin-top: 8px; }
  .meta { color: #666; font-size: 0.82rem; }
</style>
</head>
<body>

<h1>scLens Data Profile Report</h1>
<p class="meta">Task: {{ summary.taskId }} &nbsp;|&nbsp; Pipeline: {{ summary.pipeline }}</p>

<div class="card">
  <h2>Dataset Overview</h2>
  <table>
    <tr><th>Cells (obs)</th><td>{{ summary.nObs | int }}</td></tr>
    <tr><th>Genes (var)</th><td>{{ summary.nVars | int }}</td></tr>
    <tr><th>Sparsity</th><td>{{ "%.1f"|format(summary.sparsity * 100) }}%</td></tr>
    <tr><th>Has X matrix</th><td>{{ "Yes" if summary.hasX else "No" }}</td></tr>
    <tr><th>Layers</th><td>{{ summary.layers | join(", ") or "—" }}</td></tr>
    <tr><th>obsm keys</th><td>{{ summary.obsm | join(", ") or "—" }}</td></tr>
    <tr><th>uns keys</th><td>{{ summary.uns | join(", ") or "—" }}</td></tr>
  </table>
</div>

<div class="card">
  <h2>Pre-existing Results</h2>
  <table>
    <tr>
      <th>PCA</th>
      <td><span class="badge {{ 'badge-green' if summary.hasPca else 'badge-gray' }}">{{ "Found" if summary.hasPca else "Not found" }}</span></td>
    </tr>
    <tr>
      <th>UMAP</th>
      <td><span class="badge {{ 'badge-green' if summary.hasUmap else 'badge-gray' }}">{{ "Found" if summary.hasUmap else "Not found" }}</span></td>
    </tr>
    <tr>
      <th>Clusters</th>
      <td>
        {% if summary.hasClusters %}
          <span class="badge badge-green">{{ summary.clusterKey }} ({{ summary.nClusters }} clusters)</span>
        {% else %}
          <span class="badge badge-gray">Not found</span>
        {% endif %}
      </td>
    </tr>
  </table>
</div>

<div class="card">
  <h2>QC Summary</h2>
  <table>
    <tr><th>Median genes per cell</th><td>{{ summary.qc.medianGenes }}</td></tr>
    <tr><th>Median counts per cell</th><td>{{ summary.qc.medianCounts }}</td></tr>
    <tr><th>Median % mitochondrial</th><td>{{ summary.qc.medianPctMt }}%</td></tr>
  </table>
  {% if "figures/violin_qc.png" in summary.figures and figures_b64.get("figures/violin_qc.png") %}
  <img src="{{ figures_b64['figures/violin_qc.png'] }}" alt="QC violin plot" class="figure">
  {% endif %}
</div>

<div class="card">
  <h2>obs Fields ({{ summary.obsFields | length }})</h2>
  <p>{{ summary.obsFields | join(", ") or "—" }}</p>
</div>

<div class="card">
  <h2>var Fields ({{ summary.varFields | length }})</h2>
  <p>{{ summary.varFields | join(", ") or "—" }}</p>
</div>

<p class="meta" style="margin-top:32px">Generated by scLens Analysis Core · Pipeline: sc_profile_basic</p>
</body>
</html>
