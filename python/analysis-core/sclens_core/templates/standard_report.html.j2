<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>scLens Standard Analysis — {{ summary.taskId }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; padding: 24px; background: #f5f5f5; color: #222; }
  h1 { font-size: 1.4rem; color: #1a1a2e; border-bottom: 2px solid #4C72B0; padding-bottom: 8px; }
  h2 { font-size: 1.1rem; color: #333; margin-top: 28px; }
  .card { background: #fff; border-radius: 8px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
  table { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
  th { background: #f0f4ff; text-align: left; padding: 8px 12px; }
  td { padding: 7px 12px; border-bottom: 1px solid #eee; }
  .figures { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 12px; }
  .figures img { max-width: 340px; border-radius: 4px; border: 1px solid #e0e0e0; }
  .meta { color: #666; font-size: 0.82rem; }
</style>
</head>
<body>

<h1>scLens Standard Analysis Report</h1>
<p class="meta">Task: {{ summary.taskId }} &nbsp;|&nbsp; Pipeline: {{ summary.pipeline }}</p>

<div class="card">
  <h2>Cell / Gene Counts</h2>
  <table>
    <tr><th>Input cells</th><td>{{ summary.nObsInput }}</td></tr>
    <tr><th>Input genes</th><td>{{ summary.nVarsInput }}</td></tr>
    <tr><th>Cells after QC</th><td>{{ summary.nObsAfterQc }} <span style="color:#888">({{ summary.qc.cellsFiltered }} removed)</span></td></tr>
    <tr><th>Genes after QC</th><td>{{ summary.nVarsAfterQc }} <span style="color:#888">({{ summary.qc.genesFiltered }} removed)</span></td></tr>
    <tr><th>Highly variable genes</th><td>{{ summary.nHvg }}</td></tr>
    <tr><th>Leiden clusters</th><td>{{ summary.nClusters }}</td></tr>
  </table>
</div>

<div class="card">
  <h2>Analysis Parameters</h2>
  <table>
    <tr><th>Min genes / cell</th><td>{{ summary.params.qc.minGenes }}</td></tr>
    <tr><th>Min cells / gene</th><td>{{ summary.params.qc.minCells }}</td></tr>
    <tr><th>Max % mito</th><td>{{ summary.params.qc.maxPercentMito }}%</td></tr>
    <tr><th>Mito prefix</th><td>{{ summary.params.qc.mitoGenePrefix }}</td></tr>
    <tr><th>Normalize total target</th><td>{{ summary.params.preprocess.targetSum | int }}</td></tr>
    <tr><th>Highly variable genes</th><td>{{ summary.params.preprocess.nTopGenes }}</td></tr>
    <tr><th>PCA components</th><td>{{ summary.params.dimensionReduction.nPcs }}</td></tr>
    <tr><th>Neighbors (k)</th><td>{{ summary.params.dimensionReduction.nNeighbors }}</td></tr>
    <tr><th>Leiden resolution</th><td>{{ summary.params.clustering.resolution }}</td></tr>
    <tr><th>Marker method</th><td>{{ summary.params.markers.method }}</td></tr>
    <tr><th>Markers per cluster</th><td>{{ summary.params.markers.nGenes }}</td></tr>
  </table>
</div>

<div class="card">
  <h2>Figures</h2>
  <div class="figures">
    {% for fig in summary.figures %}
    {% if figures_b64.get(fig) %}
    <img src="{{ figures_b64[fig] }}" alt="{{ fig }}">
    {% endif %}
    {% endfor %}
  </div>
</div>

<div class="card">
  <h2>Output Files</h2>
  <ul>
    {% for f in summary.figures %}<li>{{ f }}</li>{% endfor %}
    {% for t in summary.tables %}<li>{{ t }}</li>{% endfor %}
  </ul>
</div>

<p class="meta" style="margin-top:32px">Generated by scLens Analysis Core · Pipeline: sc_standard_analysis</p>
</body>
</html>
